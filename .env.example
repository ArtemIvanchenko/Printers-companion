# Windows Docker Desktop defaults.
APP_ENV=local
LOG_LEVEL=INFO

POSTGRES_DB=printer_logs
POSTGRES_USER=printer_logs
POSTGRES_PASSWORD=change-me
# Use the psycopg2 driver — that's what the images install (psycopg2-binary in
# requirements.base.txt). The psycopg (v3) driver is NOT installed in the
# api/worker/scheduler images, so a `+psycopg` URL would fail to connect.
DATABASE_URL=postgresql+psycopg2://printer_logs:change-me@postgres:5432/printer_logs

REDIS_URL=redis://redis:6379/0

MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio
MINIO_BUCKET_RAW=raw-logs
MINIO_BUCKET_REPORTS=reports
MINIO_SECURE=false

# Where the printer logs live on the host. Default is the project's own Logs/
# folder (relative to docker-compose.yml), so the whole setup is self-contained.
# You can still point this at any absolute path, e.g. RAW_LOGS_HOST_PATH=C:\PrinterLogs
RAW_LOGS_HOST_PATH=./Logs
RAW_LOGS_CONTAINER_PATH=/mnt/raw_logs
# Watch the raw-logs root directly — operators drop files straight into
# C:\PrinterLogs (no \incoming subfolder), matching the README. The watcher
# must look here or new files are only picked up by the slower startup scan.
INCOMING_PATH=/mnt/raw_logs
WATCH_MODE=filesystem_events
REQUIRE_OPERATOR_IMPORT_CONFIRMATION=true
FILE_STABILITY_SECONDS=60
FILE_STABILITY_RETRY_SECONDS=30
IMPORT_CONFIRMATION_TIMEOUT_HOURS=24

API_HOST=0.0.0.0
API_PORT=8000
# Host interface the published ports bind to. Default 127.0.0.1 keeps the API,
# MinIO, MCP and Watchtower reachable only from the printer PC itself.
# Set BIND_HOST=0.0.0.0 only if you intentionally want LAN access.
BIND_HOST=127.0.0.1
INTERNAL_API_URL=http://api:8000
WORKER_CONCURRENCY=2

LLM_PROVIDER=lmstudio
LLM_BASE_URL=http://host.docker.internal:1234/v1
LLM_MODEL=qwen3.6
LLM_API_KEY=lm-studio
LLM_TIMEOUT_SEC=300
LLM_TEMPERATURE=0.1
LLM_TOP_P=0.9
LLM_MAX_TOKENS=8192

DAILY_REVIEW_CRON=0 20 * * *
HISTORICAL_REANALYSIS_CRON=0 2 * * *
HISTORICAL_REANALYSIS_WINDOW_DAYS=90
HISTORICAL_REANALYSIS_MAX_ITERATIONS=10

# TELEGRAM_BOT_TOKEN — не указывать здесь!
# Создайте .env.secrets (gitignored) c: TELEGRAM_BOT_TOKEN=реальный_токен
# А здесь укажите SHA256 хэш от токена для проверки целостности
TELEGRAM_BOT_TOKEN_HASH=
TELEGRAM_DEFAULT_CHAT_ID=
TELEGRAM_PROXY_URL=
VOICE_TRANSCRIPTION_ENABLED=true
VOICE_TRANSCRIPTION_PROVIDER=faster_whisper
VOICE_TRANSCRIPTION_MODEL=medium
VOICE_TRANSCRIPTION_LANGUAGE=ru
VOICE_TRANSCRIPTION_DEVICE=cpu
VOICE_TRANSCRIPTION_COMPUTE_TYPE=int8
VOICE_TRANSCRIPTION_MODEL_CACHE=/models/stt
AGENT_API_TOKEN=change-me-agent-token
API_SERVICE_TOKEN=change-me-service-token

LOG_RETENTION_DAYS=90
