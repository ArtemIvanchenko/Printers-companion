# Этот файл — для переопределения дефолтов. Без него тоже всё работает.
# Чтобы изменить настройки: cp .env.example .env, затем отредактируйте .env.

# ── Пути ──────────────────────────────────────────────────────────────────────
# Папка на хосте, куда кладутся логи принтера (по умолчанию ./raw_logs).
# RAW_LOGS_HOST_PATH=./raw_logs

# ── База данных ────────────────────────────────────────────────────────────────
# Пароль PostgreSQL (по умолчанию change-me — подходит для localhost).
# POSTGRES_PASSWORD=change-me
# DATABASE_URL=postgresql+psycopg://printer_logs:change-me@postgres:5432/printer_logs

# ── LLM (опционально) ─────────────────────────────────────────────────────────
# Отключён по умолчанию. Для включения:
# LLM_PROVIDER=lmstudio
# LLM_BASE_URL=http://host.docker.internal:1234/v1
# LLM_MODEL=qwen3.6

# ── Прочее ────────────────────────────────────────────────────────────────────
# Полный список переменных с дефолтами — в x-app-env секции docker-compose.yml.
