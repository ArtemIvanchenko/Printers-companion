# syntax=docker/dockerfile:1.7
# mcp image — Model Context Protocol server. Needs only the core tier plus the `mcp`
# package; no analytics. Inherits FROM base so it shares the core layer with every
# other service instead of duplicating a standalone python:3.11-slim install.
FROM ghcr.io/artemivanchenko/printers-companion:base

RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --progress-bar off "mcp>=1.0.0"

COPY . /app
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --progress-bar off --no-deps -e .

EXPOSE 8100
USER app
CMD ["python", "-m", "mcp_server.main"]

# Version metadata — injected at build time by release.sh
ARG APP_VERSION=dev
ARG GIT_COMMIT=unknown
ARG BUILD_DATE=unknown
ENV APP_VERSION=$APP_VERSION \
    GIT_COMMIT=$GIT_COMMIT \
    BUILD_DATE=$BUILD_DATE
LABEL org.opencontainers.image.version="$APP_VERSION" \
      org.opencontainers.image.revision="$GIT_COMMIT" \
      org.opencontainers.image.created="$BUILD_DATE" \
      org.opencontainers.image.source="https://github.com/artemivanchenko/printer-log-analytics"
